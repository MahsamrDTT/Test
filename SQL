into #rates_Cashout_WTR_Rate
from REF_COAL_Cashout_Rate
group by EmployeeID -- 3739 employees w/o night shift filter

-- 1SAP Employees with 0 compensation amount vs. non-zero amounts (i.e. for each emp, how many 0s, and many distinct non-zeroes)
drop table if exists #zeroes_Cashout_Rate
select EmployeeID, count(*) as Number_of_zeroes
into #zeroes_Cashout_Rate
from REF_COAL_Cashout_Rate
where compensationAmount = 0
group by EmployeeID

drop table if exists #zeroes_Cashout_Rate_WTR
select EmployeeID, count(*) as Number_of_zeroes
into #zeroes_Cashout_Rate_WTR
from REF_COAL_Cashout_Rate
where Amount = 0 or AMOUNT IS NULL
group by EmployeeID

drop table if exists #non_zeroes_Cashout_Rate
select EmployeeID, count(distinct compensationAmount) as Distinct_non_zeroes
into #non_zeroes_Cashout_Rate
from REF_COAL_Cashout_Rate
where compensationAmount > 0
group by EmployeeID

drop table if exists #non_zeroes_Cashout_Rate_WTR
select EmployeeID, count(distinct compensationAmount) as Distinct_non_zeroes
into #non_zeroes_Cashout_Rate_WTR
from REF_COAL_Cashout_Rate
where Amount > 0 AND Amount IS NOT NULL
group by EmployeeID

select a.EmployeeID as EmployeeID, a.Number_of_Rates as Number_of_Effective_Rates, b.Number_of_WTR_Rates as Number_of_WTR_Rates, COALESCE(c.Number_of_zeroes, 0) as Number_of_zeroes, COALESCE(d.Number_of_zeroes, 0) as Number_of_zeroes_WTR, COALESCE(e.Distinct_non_zeroes, 0) as Distinct_non_zeroes, COALESCE(f.Distinct_non_zeroes, 0) as Distinct_non_zeroes_WTR
from #rates_Cashout_Rate a
full outer join #rates_Cashout_WTR_Rate b
on a.EmployeeID = b.EmployeeID
full outer join #zeroes_Cashout_Rate c
on a.EmployeeID = c.EmployeeID
full outer join #zeroes_Cashout_Rate_WTR d
on a.EmployeeID = d.EmployeeID
full outer join #non_zeroes_Cashout_Rate e
on a.EmployeeID = e.EmployeeID
full outer join #non_zeroes_Cashout_Rate_WTR f
on a.EmployeeID = f.EmployeeID
